# Optional: Endpoint for outbound sync from the local queue.
# Expected: POST JSON payload, idempotent by X-Idempotency-Key header.
# Recommended with scripts/prod-server.mjs: use the same-origin proxy.
# Browser calls /sync on the PWA origin; the Node server forwards to PWA_SYNC_PROXY_TARGET.
# Example: VITE_SYNC_ENDPOINT=/sync
# Direct LAN endpoint still works, but browsers may prompt for Local Network Access:
# VITE_SYNC_ENDPOINT=https://192.168.178.250:8787/sync
VITE_SYNC_ENDPOINT=

# Optional runtime setting for scripts/prod-server.mjs.
# Default: PWA_SYNC_PROXY_TARGET=https://127.0.0.1:8787
# Set PWA_SYNC_PROXY_TLS_VERIFY=1 only when the sync-server certificate validates for the target host.

# Optional: Web Push subscription backend endpoint.
# This endpoint should accept POST JSON with the browser subscription payload.
# Example: VITE_PUSH_SUBSCRIBE_ENDPOINT=https://192.168.178.250:8787/push/subscribe
VITE_PUSH_SUBSCRIBE_ENDPOINT=

# Optional: VAPID public key used for PushManager.subscribe.
# Required to create browser push subscriptions.
# Example: VITE_WEB_PUSH_PUBLIC_KEY=BK...your_public_key...
VITE_WEB_PUSH_PUBLIC_KEY=

# Optional HTTPS certificate overrides for local dev.
# If unset, Vite uses .cert/dev-cert.pem and .cert/dev-key.pem.
# DEV_CERT_FILE=/home/_vb/card-sync-server/certs/cert.pem
# DEV_KEY_FILE=/home/_vb/card-sync-server/certs/key.pem

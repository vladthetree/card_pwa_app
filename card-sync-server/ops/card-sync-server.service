[Unit]
Description=Card Sync Server (HTTPS)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/card_pwa_app/card-sync-server
EnvironmentFile=-%h/card_pwa_app/card-sync-server/.env.sync-server
ExecStart=/bin/bash -lc 'source %h/card_pwa_app/card-sync-server/.venv/bin/activate && exec python3 %h/card_pwa_app/card-sync-server/sync_server.py'
Restart=always
RestartSec=3
StandardOutput=append:%h/card_pwa_app/card-sync-server/logs/systemd-sync-server.out.log
StandardError=append:%h/card_pwa_app/card-sync-server/logs/systemd-sync-server.err.log

[Install]
WantedBy=default.target
